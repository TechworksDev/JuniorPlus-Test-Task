{
  "name": "techworks-backend",
  "version": "1.0.0",
  "description": "Techworks note-manager test project",
  "license": "ISC",
  "author": "Nekorynn (rynn-lee)",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "cross-env DATABASE_URL=postgres://user:password@localhost:5432/appdb node-pg-migrate up",
    "migrate:down": "cross-env DATABASE_URL=postgres://user:password@localhost:5432/appdb node-pg-migrate down"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.1",
    "@types/pg": "^8.15.5",
    "cross-env": "^10.0.0",
    "node-pg-migrate": "^8.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
